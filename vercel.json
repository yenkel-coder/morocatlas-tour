{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "dist/server/server.js": {
      "runtime": "@vercel/node@4",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/server.js"
    }
  ]
}
